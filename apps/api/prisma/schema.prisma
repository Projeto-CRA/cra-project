generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

enum UserRole {
  LEADER
  SUPERVISOR
  ADMIN
}

enum CycleStatus {
  IN_PROGRESS
  PAUSED
  FINISHED
}

enum SupplyType {
  NYLON
  GASOLINE
}

enum SupplyUnit {
  METER
  LITER
}

enum PhotoMoment {
  BEFORE
  AFTER
}

enum SyncStatus {
  PENDING
  SYNCING
  SYNCED
  FAILED
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  fullName     String    @map("full_name") @db.VarChar(150)
  role         UserRole  @default(LEADER)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  cycles       Cycle[]
  auditLogs    AuditLog[]

  @@map("users")
}

model Cycle {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  sectionCode String      @map("section_code") @db.VarChar(50)
  status      CycleStatus @default(IN_PROGRESS)
  startedAt   DateTime    @map("started_at") @db.Timestamptz
  pausedAt    DateTime?   @map("paused_at") @db.Timestamptz
  endedAt     DateTime?   @map("ended_at") @db.Timestamptz
  startLat    Decimal?    @map("start_lat") @db.Decimal(10, 7)
  startLng    Decimal?    @map("start_lng") @db.Decimal(10, 7)
  endLat      Decimal?    @map("end_lat") @db.Decimal(10, 7)
  endLng      Decimal?    @map("end_lng") @db.Decimal(10, 7)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz
  user        User        @relation(fields: [userId], references: [id])
  supplies    Supply[]
  photos      Photo[]

  @@index([userId])
  @@index([status])
  @@map("cycles")
}

model Supply {
  id        String     @id @default(uuid()) @db.Uuid
  cycleId   String     @map("cycle_id") @db.Uuid
  type      SupplyType
  quantity  Decimal    @db.Decimal(10, 2)
  unit      SupplyUnit
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  cycle     Cycle      @relation(fields: [cycleId], references: [id])

  @@index([cycleId])
  @@map("supplies")
}

model Photo {
  id          String      @id @default(uuid()) @db.Uuid
  cycleId     String      @map("cycle_id") @db.Uuid
  moment      PhotoMoment
  s3Key       String      @map("s3_key") @db.VarChar(500)
  latitude    Decimal     @db.Decimal(10, 7)
  longitude   Decimal     @db.Decimal(10, 7)
  takenAt     DateTime    @map("taken_at") @db.Timestamptz
  syncStatus  SyncStatus  @default(PENDING) @map("sync_status")
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz
  cycle       Cycle       @relation(fields: [cycleId], references: [id])

  @@index([cycleId])
  @@index([syncStatus])
  @@map("photos")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String   @db.VarChar(100)
  entity    String   @db.VarChar(100)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}